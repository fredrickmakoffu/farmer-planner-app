<?xml version="1.0" encoding="utf-8"?>
<!--
  Tapp 1×1 widget layout — a single circular tap button.

  Normal state:
    widget_circle      → tinted with the predicted category color
    widget_icon_image  → Material icon for the predicted category

  Tapped state (~2.5 s after a successful log):
    widget_circle      → tinted with the logged category color
    widget_icon_image  → same category icon, confirming the log
  After feedback:
    Reverts back to normal state.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!--
      Colored circle — tinted at runtime via setColorFilter.
      fitCenter + the 1:1 intrinsic size on the oval drawable ensures the shape
      always renders as a circle regardless of the widget cell's aspect ratio.
    -->
    <ImageView
        android:id="@+id/widget_circle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="4dp"
        android:src="@drawable/widget_circle_bg"
        android:scaleType="fitCenter"
        android:contentDescription="@string/widget_tap_button_desc" />

    <!-- Material icon centered on the circle; swapped at runtime via setImageViewResource -->
    <ImageView
        android:id="@+id/widget_icon_image"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:src="@drawable/widget_ic_tap"
        android:scaleType="fitCenter"
        android:contentDescription="" />

</FrameLayout>
